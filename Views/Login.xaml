<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Week3_L1.Views.LoginPage"
             Title="LoginPage">
    <VerticalStackLayout>
        <Label Text="Login to FastAPI" FontSize="24" HorizontalOptions="Center" Margin="0,20"/>
        <Entry Placeholder="Username" Text="{Binding Username}" Margin="20,10"/>
        <Entry Placeholder="Password" IsPassword="True" Text="{Binding Password}" Margin="20,10"/>
        <Button Text="Login" Command="{Binding LoginCommand}" Margin="20,10"/>
    </VerticalStackLayout>
</ContentPage>